{
  "name": "release-board",
  "private": true,
  "scripts": {
    "migrate": "node -e \"const db = require('./server/db'); const { createMigrator } = require('./server/migrations'); createMigrator(db).up().then(() => db.close());\"",
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npx vite --port 5173",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "install:all": "npm install && cd client && npm install",
    "start": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "umzug": "^3.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.0.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}
